// prisma/schema.prisma
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum AssetCategory {
  LAPTOP
  MONITOR
  KEYBOARD
  MOUSE
  DESK
  CHAIR
  SOFTWARE
  OTHER
}

enum AssetStatus {
  IN_USE
  AVAILABLE
  MAINTENANCE
  RETIRED
}

model Asset {
  id            String        @id @default(uuid())
  name          String
  category      AssetCategory
  status        AssetStatus
  assignedTo    String?
  purchaseDate  DateTime
  warrantyExpiry DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  role      UserRole  @default(ADMIN) // Admin only for v1
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum UserRole {
  ADMIN
}
