{
  "name": "it-assets-inventory",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "dev": "concurrently \"pnpm run backend:dev\" \"pnpm run frontend:dev\"",
    "build": "pnpm -r build",
    "start": "pnpm -r start",
    "lint": "pnpm -r lint",
    "backend:dev": "pnpm --dir backend start:dev",
    "frontend:dev": "pnpm --dir frontend dev"
  },
  "devDependencies": {
    "@types/node": "^20",
    "concurrently": "^9.2.1",
    "typescript": "^5"
  }
}
